package com.archer.Expense_Tracker.model;

import java.math.BigDecimal;

public class Cost {
	
	private String id;
	private String expenseName;
	private ExpenseCategory expenseType;
	private BigDecimal expenseCost;
	
	
	public Cost(String id, String expenseName, ExpenseCategory expenseType, BigDecimal expenseCost) {
		super();
		this.id = id;
		this.expenseName = expenseName;
		this.expenseType = expenseType;
		this.expenseCost = expenseCost;
	}
	
	public Cost() {
		super();
	}
	
	
	public String getId() {
		return id;
	}
	public void setId(String id) {
		this.id = id;
	}
	public String getExpenseName() {
		return expenseName;
	}
	public void setExpenseName(String expenseName) {
		this.expenseName = expenseName;
	}
	public ExpenseCategory getExpenseType() {
		return expenseType;
	}
	public void setExpenseType(ExpenseCategory expenseType) {
		this.expenseType = expenseType;
	}
	public BigDecimal getExpenseCost() {
		return expenseCost;
	}
	public void setExpenseCost(BigDecimal expenseCost) {
		this.expenseCost = expenseCost;
	}

	@Override
	public String toString() {
		return "Cost [id=" + id + ", expenseName=" + expenseName + ", expenseType=" + expenseType + ", expenseCost="
				+ expenseCost + "]";
	}
	
	
	
}
